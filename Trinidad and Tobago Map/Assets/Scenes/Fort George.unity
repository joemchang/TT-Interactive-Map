  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Perched 1,100 feet above sea level, Fort George is a historic defensive
    landmark offering the most breathtaking panoramic views of Port of Spain and
    the Gulf of Paria. Built in 1804 by Governor Sir Thomas Hislop, this former military
    bastion features original cannons, intricate stonework, and a signal station
    designed by African Prince Kofi Nti. Today, it serves as a peaceful cultural
    retreat where visitors can explore Trinidad\u2019s colonial past while overlooking
    the coastline as far as the mountains of Venezuela on a clear day."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: b87c6d53e538e1c4d91a11d77116a107, type: 2}
